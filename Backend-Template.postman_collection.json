{
  "info": {
    "name": "Backend-Template",
    "_postman_id": "a4d5efde-6f20-4cc5-9bde-c5b66e6d7e31",
    "description": "Backend Template API collection for Auth, Admin and User flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "signupEmail", "value": "testuser1@gmail.com" },
    { "key": "signupPassword", "value": "TestPass123!" },
    { "key": "newPassword", "value": "NewPass123!" },
    { "key": "finalPassword", "value": "FinalPass123!" },
    { "key": "signupToken", "value": "" },
    { "key": "otpToken", "value": "" },
    { "key": "resetToken", "value": "" },
    { "key": "otp", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "adminEmail", "value": "superadmin@gmail.com" },
    { "key": "adminPassword", "value": "NewPass123!" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "adminRefreshToken", "value": "" },
    { "key": "adminOtpToken", "value": "" },
    { "key": "adminResetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{signupEmail}}\",\n  \"password\": \"{{signupPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.signupToken) pm.collectionVariables.set('signupToken', json.data.signupToken);",
                  "if (json?.data?.otpToken) pm.collectionVariables.set('otpToken', json.data.otpToken);",
                  "if (json?.data?.otp) pm.collectionVariables.set('otp', String(json.data.otp));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify OTP (Signup/Forgot)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "signup-token",
                "value": "{{signupToken}}",
                "disabled": true
              },
              { "key": "otp-token", "value": "{{otpToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": {{otp}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.resetToken) pm.collectionVariables.set('resetToken', json.data.resetToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{signupEmail}}\",\n  \"password\": \"{{signupPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "if (json?.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{signupEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.otpToken) pm.collectionVariables.set('otpToken', json.data.otpToken);",
                  "if (json?.data?.otp) pm.collectionVariables.set('otp', String(json.data.otp));"
                ]
              }
            }
          ]
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "reset-token", "value": "{{resetToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"{{newPassword}}\",\n  \"confirmPassword\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{signupPassword}}\",\n  \"newPassword\": \"{{finalPassword}}\",\n  \"confirmPassword\": \"{{finalPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "change-password"]
            }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "signup-token",
                "value": "{{signupToken}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{signupEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "resend-otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.otpToken) pm.collectionVariables.set('otpToken', json.data.otpToken);",
                  "if (json?.data?.otp) pm.collectionVariables.set('otp', String(json.data.otp));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "refreshtoken", "value": "{{refreshToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh-token"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);"
                ]
              }
            }
          ]
        }
      ]
    },
